---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import CalculatorPanel from "../components/CalculatorPanel.astro";
import { withBase } from "../lib/paths";

const monthNames = [
  "Enero",
  "Febrero",
  "Marzo",
  "Abril",
  "Mayo",
  "Junio",
  "Julio",
  "Agosto",
  "Septiembre",
  "Octubre",
  "Noviembre",
  "Diciembre"
];

const calendarEntries = (await getCollection("calendar")).sort((a, b) => a.data.month - b.data.month);
const sections = await getCollection("sections");
const chapters = await getCollection("chapters");
const calculators = await getCollection("calculators");
const sectionMap = new Map(sections.map((section) => [section.slug, section.data.title]));
const chapterMap = new Map(chapters.map((chapter) => [chapter.slug, chapter]));
const calculatorMap = new Map(calculators.map((calculator) => [calculator.data.slug, calculator]));
const sectionFilters = sections.map((section) => ({
  slug: section.slug,
  title: section.data.title
}));

const priorityLabels = {
  low: "Rutina",
  medium: "Atenci&oacute;n",
  high: "Prioritario",
  critical: "Cr&iacute;tico"
};

const seasonBlocks = [
  {
    title: "Primavera",
    months: "Marzo - mayo",
    image: "/media/calendar/primavera-semilleros.png",
    summary: "Semilleros, trasplantes, arranque del huerto y primeras revisiones sanitarias."
  },
  {
    title: "Verano",
    months: "Junio - agosto",
    image: "/media/calendar/verano-conservas.png",
    summary: "Agua bajo control, cosecha, conservas y vigilancia de plagas."
  },
  {
    title: "Oto&ntilde;o",
    months: "Septiembre - noviembre",
    image: "/media/calendar/otono-sidra-lena.png",
    summary: "Sidra, le&ntilde;a, reservas y cierre de sistemas antes del invierno."
  },
  {
    title: "Invierno",
    months: "Diciembre - febrero",
    image: "/media/calendar/invierno-mantenimiento.png",
    summary: "Mantenimiento, seguridad, botiqu&iacute;n, captaci&oacute;n y preparaci&oacute;n de infraestructura."
  }
];

const calendarCalculatorSlugs = Array.from(
  new Set(calendarEntries.flatMap((entry) => entry.data.calculatorSlugs))
);
const calendarCalculators = calendarCalculatorSlugs
  .map((slug) => calculatorMap.get(slug))
  .filter((entry): entry is NonNullable<typeof entry> => Boolean(entry));

const criticalEntries = calendarEntries.filter((entry) => entry.data.priority === "critical");
const highEntries = calendarEntries.filter((entry) => entry.data.priority === "high");
const highlightedEntries = Array.from(new Set([...criticalEntries, ...highEntries, ...calendarEntries])).slice(0, 3);

const groupedByMonth = monthNames.map((name, index) => ({
  monthNumber: index + 1,
  monthName: name,
  entries: calendarEntries.filter((entry) => entry.data.month === index + 1)
}));
---

<BaseLayout title="Calendario anual | S&aacute;lvese Quien Pueda">
  <main class="page-shell">
    <section class="calendar-hero">
      <div class="calendar-hero__copy">
        <p class="eyebrow">Herramienta transversal</p>
        <h1>Calendario operativo anual</h1>
        <p class="lede">
          Una lectura de la finca por estaciones: qu&eacute; revisar, qu&eacute; calcular y qu&eacute;
          cap&iacute;tulo abrir cuando toca tomar una decisi&oacute;n pr&aacute;ctica.
        </p>
      </div>
      <figure class="calendar-hero__image">
        <img
          src={withBase("/media/calendar/calendario-operativo-hero.png")}
          alt="Mesa de trabajo rural con tierra, alimento y planificacion de temporada"
        />
      </figure>
    </section>

    <section class="calendar-focus">
      <div class="calendar-focus__intro">
        <p class="eyebrow">Prioridades</p>
        <h2>Lo que no conviene dejar para luego</h2>
        <p>
          Este bloque separa las tareas de mayor riesgo operativo del ruido mensual:
          agua, reservas, seguridad y ventanas de trabajo que se pierden si se retrasan.
        </p>
      </div>
      <div class="calendar-focus__cards">
        {highlightedEntries.map((entry) => (
          <article>
            <span>{monthNames[entry.data.month - 1]}</span>
            <strong set:html={priorityLabels[entry.data.priority]} />
            <h3>{entry.data.title}</h3>
            <p>{entry.data.summary}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="season-grid" aria-label="Ritmo estacional">
      {seasonBlocks.map((season) => (
        <article class="season-card">
          <img src={withBase(season.image)} alt={`Trabajo de finca en ${season.title}`} />
          <div>
            <p class="eyebrow">{season.months}</p>
            <h2 set:html={season.title} />
            <p set:html={season.summary} />
          </div>
        </article>
      ))}
    </section>

    <section class="calendar-toolbar" data-calendar-root>
      <div class="calendar-toolbar__group">
        <label for="calendar-month">Mes</label>
        <select id="calendar-month" data-calendar-month>
          <option value="all">Todo el a&ntilde;o</option>
          {monthNames.map((month, index) => (
            <option value={`${index + 1}`}>{month}</option>
          ))}
        </select>
      </div>

      <div class="calendar-toolbar__group">
        <label for="calendar-section">Tema</label>
        <select id="calendar-section" data-calendar-section>
          <option value="all">Todas las secciones</option>
          {sectionFilters.map((section) => (
            <option value={section.slug}>{section.title}</option>
          ))}
        </select>
      </div>
    </section>

    {calendarCalculators.length > 0 && (
      <section class="calendar-calculators" aria-labelledby="calendar-calculators-title">
        <div class="cover-section-heading">
          <p class="eyebrow">Calculadoras de temporada</p>
          <h2 id="calendar-calculators-title">N&uacute;meros que cambian decisiones</h2>
          <p>
            El calendario no debe limitarse a recordar tareas: cuando una tarea depende
            de volumen, superficie, reserva o rendimiento, aqu&iacute; aparece su calculadora.
          </p>
        </div>
        <CalculatorPanel calculators={calendarCalculators} />
      </section>
    )}

    <section class="calendar-board" data-calendar-board>
      {groupedByMonth.map((group) => (
        <article class="calendar-month-card" data-month={group.monthNumber}>
          <header class="calendar-month-card__header">
            <p class="eyebrow">{group.monthNumber}</p>
            <h2>{group.monthName}</h2>
          </header>

          <div class="calendar-month-card__body">
            {group.entries.length > 0 ? (
              group.entries.map((entry) => (
                <article class="calendar-entry-card" data-section={entry.data.sectionSlug}>
                  <div class="calendar-entry-card__meta">
                    <span>{entry.data.taskType}</span>
                    <span set:html={priorityLabels[entry.data.priority]} />
                  </div>
                  <h3>{entry.data.title}</h3>
                  <p>{entry.data.summary}</p>
                  <div class="calendar-entry-card__links">
                    <small>{sectionMap.get(entry.data.sectionSlug)}</small>
                    {entry.data.relatedChapterSlugs.map((slug) => {
                      const chapter = chapterMap.get(slug);
                      if (!chapter) return null;
                      return (
                        <a href={withBase(`/secciones/${chapter.data.sectionSlug}/${chapter.slug}/`)}>
                          Abrir cap&iacute;tulo
                        </a>
                      );
                    })}
                    {entry.data.calculatorSlugs.map((slug) => {
                      const calculator = calculatorMap.get(slug);
                      if (!calculator) return null;
                      return <a href="#calendar-calculators-title">Calcular: {calculator.data.title}</a>;
                    })}
                  </div>
                </article>
              ))
            ) : (
              <p class="calendar-empty">Sin tareas registradas para este mes.</p>
            )}
          </div>
        </article>
      ))}
    </section>

    <script>
      const root = document.querySelector("[data-calendar-root]");
      const board = document.querySelector("[data-calendar-board]");

      if (root instanceof HTMLElement && board instanceof HTMLElement) {
        const monthSelect = root.querySelector("[data-calendar-month]");
        const sectionSelect = root.querySelector("[data-calendar-section]");
        const monthCards = Array.from(board.querySelectorAll("[data-month]"));

        if (monthSelect instanceof HTMLSelectElement && sectionSelect instanceof HTMLSelectElement) {
          const applyFilters = () => {
            const monthValue = monthSelect.value;
            const sectionValue = sectionSelect.value;

            monthCards.forEach((monthCard) => {
              if (!(monthCard instanceof HTMLElement)) return;

              const monthMatches = monthValue === "all" || monthCard.dataset.month === monthValue;
              const entries = Array.from(monthCard.querySelectorAll("[data-section]"));
              let visibleEntries = 0;

              entries.forEach((entry) => {
                if (!(entry instanceof HTMLElement)) return;

                const sectionMatches = sectionValue === "all" || entry.dataset.section === sectionValue;
                const visible = monthMatches && sectionMatches;
                entry.style.display = visible ? "" : "none";
                if (visible) visibleEntries += 1;
              });

              const emptyNode = monthCard.querySelector(".calendar-empty");
              if (emptyNode instanceof HTMLElement) {
                emptyNode.style.display = visibleEntries === 0 ? "" : "none";
              }

              monthCard.style.display =
                monthMatches && (visibleEntries > 0 || sectionValue === "all") ? "" : "none";
            });
          };

          monthSelect.addEventListener("change", applyFilters);
          sectionSelect.addEventListener("change", applyFilters);
          applyFilters();
        }
      }
    </script>
  </main>
</BaseLayout>
