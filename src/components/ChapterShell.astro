---
import ChapterHero from "./ChapterHero.astro";
import { withBase } from "../lib/paths";

interface Metric {
  label: string;
  value: string;
  note?: string;
}

interface Props {
  sectionTitle: string;
  sectionHref: string;
  chapterLabel?: string;
  title: string;
  summary?: string;
  metrics?: Metric[];
}

const { sectionTitle, sectionHref, chapterLabel, title } = Astro.props;
---

<div class="chapter-shell">
  <div class="chapter-shell__main">
    <a href={withBase(sectionHref)} class="back-link">Volver a {sectionTitle}</a>
    <ChapterHero
      eyebrow={chapterLabel}
      title={title}
    />
    <article class="reading-surface editorial-prose">
      <slot />
    </article>
  </div>
</div>
